# Big Homie Environment Configuration
# Copy this file to .env and fill in your API keys

# Application
DEBUG=false
APP_NAME=Big Homie
APP_VERSION=1.0.0

# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-v1-...

# GitHub Copilot
GITHUB_TOKEN=ghp_...
COPILOT_ENABLED=false

# Local Models (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=false

# Model Selection
DEFAULT_MODEL=claude-sonnet-4-5
REASONING_MODEL=claude-opus-4-5
FAST_MODEL=claude-haiku
CODING_MODEL=gpt-4

# API Services
SERP_API_KEY=

# Finance (Alpaca)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=9000
ORCHESTRATOR_SECRET=change-me-in-production

# Memory Paths
MEMORY_DB_PATH=~/.big_homie/memory.db
VECTOR_DB_PATH=~/.big_homie/vectors.db

# Agent Settings
MAX_ITERATIONS=25
TEMPERATURE=0.7
MAX_TOKENS=4096

# Cost Tracking
TRACK_COSTS=true
COST_ALERT_THRESHOLD=10.0

# UI Settings
UI_THEME=dark
UI_FONT_SIZE=12

# ===== Deep Integrations =====

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ENABLED=false

# Vercel
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
VERCEL_ENABLED=false

# Google Cloud Platform
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
GOOGLE_CLOUD_ENABLED=false

# Perplexity AI
PERPLEXITY_API_KEY=
PERPLEXITY_ENABLED=false
PERPLEXITY_MODEL=llama-3.1-sonar-large-128k-online

# Stripe Payments
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ENABLED=false

# Coinbase Commerce
COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=
COINBASE_COMMERCE_ENABLED=false

# Base Layer 2 (Ethereum)
BASE_RPC_URL=https://mainnet.base.org
BASE_WALLET_ADDRESS=
BASE_WALLET_PRIVATE_KEY=
BASE_ENABLED=false

# DraftKings
DRAFTKINGS_API_KEY=
DRAFTKINGS_ENABLED=false

# PrizePicks
PRIZEPICKS_API_KEY=
PRIZEPICKS_ENABLED=false

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
